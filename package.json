{
  "name": "@thomas-inst/typesetter",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "test": "vitest run",
    "prebuild": "rm -rf dist",
    "build": "rollup -c"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./LineBreaker": {
      "import": "./dist/LineBreaker/index.js",
      "types": "./dist/LineBreaker/index.d.ts"
    },
    "./Renderer": {
      "import": "./dist/Renderer/index.js",
      "types": "./dist/Renderer/index.d.ts"
    },
    "./PageProcessor": {
      "import": "./dist/PageProcessor/index.js",
      "types": "./dist/PageProcessor/index.d.ts"
    },
    "./TextBoxMeasurer": {
      "import": "./dist/TextBoxMeasurer/index.js",
      "types": "./dist/TextBoxMeasurer/index.d.ts"
    },
    "./Bidi": {
      "import": "./dist/Bidi/index.js",
      "types": "./dist/Bidi/index.d.ts"
    },
    "./Style": {
      "import": "./dist/Style/index.js",
      "types": "./dist/Style/index.d.ts"
    },
    "./Compactor": {
      "import": "./dist/Compactor/index.js",
      "types": "./dist/Compactor/index.d.ts"
    },
    "./Hyphenator": {
      "import": "./dist/Hyphenator/index.js",
      "types": "./dist/Hyphenator/index.d.ts"
    },
    "./Hyphenator/patterns": {
      "import": "./dist/Hyphenator/patterns/index.js",
      "types": "./dist/Hyphenator/patterns/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "package.json",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thomas-institut/typesetter.git"
  },
  "keywords": [],
  "author": "Rafael Nájera <rafael.najera@uni-koeln.de>",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/thomas-institut/typesetter/issues"
  },
  "homepage": "https://github.com/thomas-institut/typesetter#readme",
  "dependencies": {
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^24.0.10",
    "rollup": "4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
